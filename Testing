local function createSupeLabel(text, color)
	if not supeEnabled then return end
	local screenGui = player.PlayerGui:FindFirstChild("AnimationHUD")
	if not screenGui then return end
	local label = Instance.new("TextLabel")
	label.Name = "SupeLabel"
	label.Size = UDim2.new(0, 300, 0, 22)
	label.Position = UDim2.new(1, -310, 0, 10 + #supeLabels * 24)
	label.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	label.BackgroundTransparency = 0.3
	label.TextColor3 = color or Color3.new(1, 1, 1)
	label.Text = text
	label.TextScaled = true
	label.Font = Enum.Font.Gotham
	label.TextXAlignment = Enum.TextXAlignment.Right
	label.Parent = screenGui
	table.insert(supeLabels, label)
	if #supeLabels > MAX_SUPE_MESSAGES then
		local old = table.remove(supeLabels, 1)
		if old and old.Parent then old:Destroy() end
	end
	task.delay(3, function()
		if label and label.Parent then
			for i, lbl in ipairs(supeLabels) do
				if lbl == label then
					table.remove(supeLabels, i)
					break
				end
			end
			label:Destroy()
			for i, lbl in ipairs(supeLabels) do
				lbl.Position = UDim2.new(1, -310, 0, 10 + (i - 1) * 24)
			end
		end
	end)
	for i, lbl in ipairs(supeLabels) do
		lbl.Position = UDim2.new(1, -310, 0, 10 + (i - 1) * 24)
	end
end

local function setupSupeEvents()
	for _, c in pairs(supeConnections) do c:Disconnect() end
	supeConnections = {}
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player then
			local char = plr.Character
			if char and char:FindFirstChild("Humanoid") then
				local hum = char:FindFirstChild("Humanoid")
				local dc = hum.Died:Connect(function()
					createSupeLabel(plr.Name .. " died", Color3.fromRGB(255,80,80))
					dc:Disconnect()
				end)
				table.insert(supeConnections, dc)
			end
		end
	end
	table.insert(supeConnections, Players.PlayerAdded:Connect(function(plr)
		if plr == player then return end
		createSupeLabel(plr.Name .. " joined", Color3.fromRGB(80,255,80))
		local cac = plr.CharacterAdded:Connect(function(char)
			local hum = char:WaitForChild("Humanoid")
			local dc = hum.Died:Connect(function()
				createSupeLabel(plr.Name .. " died", Color3.fromRGB(255,80,80))
				dc:Disconnect()
			end)
			table.insert(supeConnections, dc)
			cac:Disconnect()
		end)
		table.insert(supeConnections, cac)
	end))
	table.insert(supeConnections, Players.PlayerRemoving:Connect(function(plr)
		if plr == player then return end
		createSupeLabel(plr.Name .. " left", Color3.fromRGB(255,200,80))
	end))
end

local function toggleSupe()
	supeEnabled = not supeEnabled
	if supeEnabled then
		setupSupeEvents()
		createSupeLabel("Supe system activated", Color3.fromRGB(100,200,255))
	else
		for _, c in pairs(supeConnections) do c:Disconnect() end
		supeConnections = {}
		local sg = player.PlayerGui:FindFirstChild("AnimationHUD")
		if sg then
			for _, ch in ipairs(sg:GetChildren()) do
				if ch:IsA("TextLabel") and ch.Name == "SupeLabel" then ch:Destroy() end
			end
		end
		supeLabels = {}
	end
	updateButtonStates()
end

local function toggleXRay()
	local char, root = character, rootPart
	if not char or not root then return end
	local rootPos = root.Position
	local radius = 1000
	if not xrayEnabled then
		xrayEnabled = true
		xrayAffectedParts = {}
		for _, part in ipairs(workspace:GetDescendants()) do
			if part:IsA("BasePart") and part.Parent then
				local model = part:FindFirstAncestorOfClass("Model")
				if model and model:FindFirstChild("Humanoid") then continue end
				if (part.Position - rootPos).Magnitude <= radius then
					xrayAffectedParts[part] = part.Transparency
					part.Transparency = 0.7
				end
			end
		end
	else
		xrayEnabled = false
		for part, trans in pairs(xrayAffectedParts) do
			if part and part.Parent then part.Transparency = trans end
		end
		xrayAffectedParts = {}
	end
	updateButtonStates()
end

