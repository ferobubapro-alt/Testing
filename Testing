local xrayEnabled, xrayAffectedParts = false, {}
local supeEnabled, supeConnections, supeLabels = false, {}, {}
local flyAnimationVersion = 1

local function resetAll()
	if shared.flying or shared.floating then
		shared.flying = false
		shared.floating = false
		if bodyVelocity then bodyVelocity:Destroy(); bodyVelocity = nil end
		if bodyGyro then bodyGyro:Destroy(); bodyGyro = nil end
	end
	if shared.laserActive then shared.laserActive = false; if shared.stopLaserSound then shared.stopLaserSound() end end
	shared.laserCurrentDistance = 0
	shared.currentTrack = nil; shared.currentType = nil
	shared.shakeTime, shared.effectIntensity, shared.targetIntensity = 0,0,0
	shared.zoomProgress, shared.targetZoom = 0,0
	shared.landingCooldown = false; shared.wasInAir = false; shared.landingPosition = nil; shared.landingShakeTime = 0
	if shared.originalFOV then camera.FieldOfView = shared.originalFOV; shared.originalFOV = nil end
	if xrayEnabled then
		for part, trans in pairs(xrayAffectedParts) do
			if part and part.Parent then part.Transparency = trans end
		end
		xrayAffectedParts = {}; xrayEnabled = false
	end
	if supeEnabled then
		supeEnabled = false
		for _, c in pairs(supeConnections) do c:Disconnect() end
		supeConnections = {}
		local sg = player.PlayerGui:FindFirstChild("AnimationHUD")
		if sg then
			for _, ch in ipairs(sg:GetChildren()) do
				if ch:IsA("TextLabel") and ch.Name == "SupeLabel" then ch:Destroy() end
			end
		end
		supeLabels = {}
	end
end

local function loadAnimations(char)
	resetAll()
	character = char
	humanoid = character:WaitForChild("Humanoid")
	animator = humanoid:WaitForChild("Animator")
	rootPart = character:WaitForChild("HumanoidRootPart")
	for _, part in ipairs(character:GetDescendants()) do
		if part:IsA("BasePart") then part.CanCollide = true end
	end
	for animType, _ in pairs(shared.tracks) do
		shared.tracks[animType] = {}
	end
	for animType, idList in pairs(shared.ANIM_IDS) do
		for i, animId in ipairs(idList) do
			local animObj = Instance.new("Animation")
			animObj.AnimationId = animId
			local track = animator:LoadAnimation(animObj)
			track.Priority = Enum.AnimationPriority.Action4
			shared.tracks[animType][i] = track
		end
	end
	shared.currentIndices.Fly = flyAnimationVersion or 1
	shared.stopCurrentTrack()
	shared.updateIdleState()
end

local function onCharacterAdded(char)
	loadAnimations(char)
	char.Humanoid.Died:Connect(function() resetAll() end)
end

if shared.setReloadCallback then shared.setReloadCallback(loadAnimations) end

local lastTime = tick()
runService.RenderStepped:Connect(function(dt)
	local now = tick()
	dt = math.min(now - lastTime, 0.033)
	lastTime = now
	if not humanoid or not character or not character.Parent then return end
	if shared.landingCooldown then
		shared.updateLaser(dt)
		shared.updateCamera(dt)
		return
	end
	shared.checkEmoteCancel()
	shared.updateIdleState()
	local velocityY = rootPart.AssemblyLinearVelocity.Y
	if (shared.flying or shared.floating) and shared.wasInAir then
		local grounded = humanoid.FloorMaterial ~= Enum.Material.Air
		local rayParams = RaycastParams.new()
		rayParams.FilterType = Enum.RaycastFilterType.Exclude
		rayParams.FilterDescendantsInstances = {character}
		local hit = workspace:Raycast(rootPart.Position, Vector3.new(0, -8, 0), rayParams)
		
		if shared.settings.landingEnabled then
			if grounded or (hit and velocityY < -20) then
				shared.wasInAir = false
				if not shared.floating then
					if not (shared.laserActive and shared.settings.laserFlingEnabled) then
						shared.performLanding()
						flying = false
						shared.flying = false
						updateButtonStates()
						return
					end
				end
			end
		end
	end
	local isInAir = humanoid.FloorMaterial == Enum.Material.Air
	shared.wasInAir = isInAir
	if (shared.flying or shared.floating) and rootPart and humanoid and not shared.isFlinging then
		local currentSpeed = shared.floating and shared.floatingSpeed or shared.flySpeed
		local moveDir = humanoid.MoveDirection
		if moveDir.Magnitude > 0.05 then
			if shared.flying and shared.currentType ~= "Fly" then
				shared.playAnimation("Fly", shared.currentIndices.Fly or 1)
			end
			local forward = camera.CFrame.LookVector
			local flatForward = Vector3.new(forward.X, 0, forward.Z)
			if flatForward.Magnitude > 0 then
				flatForward = flatForward.Unit
			end
			local right = Vector3.new(camera.CFrame.RightVector.X, 0, camera.CFrame.RightVector.Z)
			if right.Magnitude > 0 then
				right = right.Unit
			end
			local forwardAmount = moveDir:Dot(flatForward)
			local rightAmount = moveDir:Dot(right)
			local velocity = flatForward * (forwardAmount * currentSpeed) +
				right * (rightAmount * currentSpeed) +
				Vector3.new(0, forward.Y * forwardAmount * currentSpeed, 0)
			bodyVelocity.Velocity = velocity
		else
			if shared.currentType ~= "FlyIdle" and shared.currentType ~= "LaserIdle" then
				shared.updateIdleState()
			end
			bodyVelocity.Velocity = Vector3.zero
		end
		shared.updateSmoothEffects(dt)
		shared.updateCamera(dt)
	elseif shared.isFlinging and bodyVelocity then
		bodyVelocity.Velocity = Vector3.new(0,0,0)
	else
		shared.updateCamera(dt)
	end
	shared.updateLaser(dt)
end)

