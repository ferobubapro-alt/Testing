local function spawnGroundBlocks(position)
	local outerRadius, innerRadius, gridSize, heightForce, lifeTime = 8, 3.5, 3, 55, 2.5
	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.FilterDescendantsInstances = {character}
	for x = -outerRadius, outerRadius, gridSize do
		for z = -outerRadius, outerRadius, gridSize do
			local dist = math.sqrt(x*x + z*z)
			if dist < innerRadius then continue end
			local result = workspace:Raycast(position + Vector3.new(x, 5, z), Vector3.new(0, -20, 0), rayParams)
			if result then
				local part = Instance.new("Part")
				part.Size = Vector3.new(gridSize, gridSize, gridSize)
				part.Anchored, part.CanCollide = false, false
				part.Material, part.Color = result.Material, result.Instance.Color
				part.Position = result.Position + Vector3.new(0, 1, 0)
				part.Parent = workspace
				local dir = Vector3.new(math.random(-10,10)/10, 1, math.random(-10,10)/10).Unit
				part:ApplyImpulse(dir * heightForce * part.AssemblyMass)
				part:ApplyAngularImpulse(Vector3.new(math.random(-15,15), math.random(-15,15), math.random(-15,15)) * part.AssemblyMass)
				task.delay(lifeTime, function() if part then part:Destroy() end end)
			end
		end
	end
end

local function stopCurrentTrack()
	if shared.currentTrack then
		shared.currentTrack:Stop(shared.CROSSFADE_TIME)
		shared.currentTrack = nil
	end
	shared.currentType = nil
end

local function playAnimation(animType, index)
	if not animator then return end
	local newTrack = shared.tracks[animType][index]
	if not newTrack then
		if reloadAnimationsCallback and character then
			reloadAnimationsCallback(character)
			newTrack = shared.tracks[animType][index]
			if not newTrack then return end
		else return end
	end
	if shared.currentTrack == newTrack and newTrack.IsPlaying then return end
	if shared.currentTrack then shared.currentTrack:Stop(shared.CROSSFADE_TIME) end
	newTrack:Play(shared.CROSSFADE_TIME)
	shared.currentTrack = newTrack
	shared.currentType = animType
	shared.currentIndices[animType] = index
end

local function updateIdleState()
	if not humanoid or not character then return end
	if not shared.flying and not shared.floating and shared.currentType ~= "Emote" then
		if shared.currentTrack then stopCurrentTrack() end
		return
	end
	if (shared.flying or shared.floating) and shared.currentType ~= "Emote" then
		local moving = humanoid.MoveDirection.Magnitude > 0.1
		if moving then
			if shared.currentType ~= "Fly" and shared.flying then
				playAnimation("Fly", shared.currentIndices.Fly)
			end
		else
			local targetAnimType = "FlyIdle"
			local targetIndex = shared.currentIndices.FlyIdle
			if shared.laserActive and shared.settings.laserIdleEnabled and shared.tracks.LaserIdle and shared.tracks.LaserIdle[1] then
				targetAnimType = "LaserIdle"
				targetIndex = 1
			end
			if shared.currentType ~= targetAnimType or shared.currentIndices[targetAnimType] ~= targetIndex then
				playAnimation(targetAnimType, targetIndex)
			end
		end
	end
end

local function checkEmoteCancel()
	if shared.currentType == "Emote" then
		local moving = humanoid and humanoid.MoveDirection.Magnitude > 0.1
		local jumping = humanoid and humanoid.Jump
		if moving or jumping then stopCurrentTrack(); updateIdleState() end
	end
end

local function updateSmoothEffects(dt)
	if not shared.flying and not shared.floating then
		shared.targetIntensity, shared.targetZoom = 0, 0
	else
		local isMoving = shared.currentType == "Fly" and (shared.flying or shared.floating)
		if shared.floating then
			shared.targetIntensity = 0
			shared.targetZoom = 0
		else
			shared.targetIntensity = isMoving and (shared.settings.cameraShake and 1 or 0) or 0
			shared.targetZoom = isMoving and (shared.settings.cameraZoom and 1 or 0) or 0
		end
	end
	local easeSpeed = 5
	shared.effectIntensity = shared.effectIntensity + (shared.targetIntensity - shared.effectIntensity) * math.min(dt * easeSpeed, 1)
	shared.zoomProgress = shared.zoomProgress + (shared.targetZoom - shared.zoomProgress) * math.min(dt * easeSpeed, 1)
	if shared.zoomProgress > 0.01 and shared.settings.cameraZoom and not shared.floating then
		if not shared.originalFOV then shared.originalFOV = camera.FieldOfView end
		camera.FieldOfView = shared.originalFOV + (95 - shared.originalFOV) * shared.zoomProgress
	elseif shared.zoomProgress <= 0.01 and shared.originalFOV then
		camera.FieldOfView = shared.originalFOV
		shared.originalFOV = nil
	end
end

local function updateCamera(dt)
	if not shared.flying and not shared.floating and shared.landingShakeTime <= 0 then return end
	if shared.landingShakeTime and shared.landingShakeTime > 0 then
		shared.landingShakeTime = shared.landingShakeTime - dt
		local intensity = 0.3 * (shared.landingShakeTime / 1)
		local offset = Vector3.new(math.sin(tick()*80)*intensity, math.cos(tick()*70)*intensity*0.5, math.sin(tick()*90)*intensity)
		camera.CFrame = camera.CFrame + offset
		return
	end
	if shared.settings.cameraFollow and bodyGyro then
		local look, up = camera.CFrame.LookVector, camera.CFrame.UpVector
		bodyGyro.CFrame = CFrame.lookAt(rootPart.Position, rootPart.Position + look, up)
	end
	if shared.effectIntensity > 0.01 and not shared.floating then
		shared.shakeTime = shared.shakeTime + dt * 30
		local intensity = 0.12 * shared.effectIntensity
		local offset = Vector3.new(math.sin(shared.shakeTime*50)*intensity, math.cos(shared.shakeTime*40)*intensity*0.5, math.sin(shared.shakeTime*45)*intensity)
		camera.CFrame = camera.CFrame + offset
	else
		shared.shakeTime = 0
	end
	if shared.settings.shoulderCamera then
		local cameraOffset = shared.settings.cameraOffset or 0
		local shoulderOffset = Vector3.new(3.2 + cameraOffset, 1.3, -1.8)
		camera.CFrame = camera.CFrame * CFrame.new(shoulderOffset)
	end
end

local function updateCollision()
	if not character then return end
	for _, part in ipairs(character:GetDescendants()) do
		if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
			part.CanCollide = not shared.flying and not shared.floating
		end
	end
	if rootPart then rootPart.CanCollide = not shared.flying and not shared.floating end
end

-- ===== YENİ TAKEOFF SİSTEMİ =====
local function startFly()
	if shared.flying then return end
	if not humanoid or not rootPart then return end

	if humanoid.FloorMaterial == Enum.Material.Air or shared.floating then
		shared.flying = true
		updateCollision()
		bodyVelocity = Instance.new("BodyVelocity")
		bodyVelocity.MaxForce = Vector3.new(1e6, 1e6, 1e6)
		bodyVelocity.Velocity = Vector3.zero
		bodyVelocity.Parent = rootPart
		bodyGyro = Instance.new("BodyGyro")
		bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
		bodyGyro.P, bodyGyro.D = 100000, 1000
		bodyGyro.Parent = rootPart
		if shared.settings.cameraFollow then
			local look, up = camera.CFrame.LookVector, camera.CFrame.UpVector
			bodyGyro.CFrame = CFrame.lookAt(rootPart.Position, rootPart.Position + look, up)
		end
		local moving = humanoid.MoveDirection.Magnitude > 0.1
		if moving then playAnimation("Fly", shared.currentIndices.Fly)
		else playAnimation("FlyIdle", shared.currentIndices.FlyIdle) end
		return
	end

	-- Takeoff cutscene kapalıysa direkt uçuş
	if not shared.settings.takeoffCutscene then
		shared.flying = true
		updateCollision()
		bodyVelocity = Instance.new("BodyVelocity")
		bodyVelocity.MaxForce = Vector3.new(1e6, 1e6, 1e6)
		bodyVelocity.Velocity = Vector3.zero
		bodyVelocity.Parent = rootPart
		bodyGyro = Instance.new("BodyGyro")
		bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
		bodyGyro.P, bodyGyro.D = 100000, 1000
		bodyGyro.Parent = rootPart
		if shared.settings.cameraFollow then
			local look, up = camera.CFrame.LookVector, camera.CFrame.UpVector
			bodyGyro.CFrame = CFrame.lookAt(rootPart.Position, rootPart.Position + look, up)
		end
		local moving = humanoid.MoveDirection.Magnitude > 0.1
		if moving then playAnimation("Fly", shared.currentIndices.Fly)
		else playAnimation("FlyIdle", shared.currentIndices.FlyIdle) end
		return
	end

	-- Camera follow'u geçici olarak kapat
	local oldCameraFollow = shared.settings.cameraFollow
	if oldCameraFollow then
		shared.settings.cameraFollow = false
	end

	shared.takeoffPlaying = true

	-- === TAKE-OFF SESİ BAŞLAT (1 saniye bekle) ===
	local sound = Instance.new("Sound")
	sound.SoundId = "rbxassetid://139473062598949"
	sound.Volume = 1
	sound.Looped = false
	sound.Parent = rootPart or character
	sound:Play()
	shared.takeoffSound = sound

	task.wait(1)

	-- Emote 1 oynat (0.80 saniye)
	playAnimation("Emote", 1)

	-- Sesin kalanı: emote bitmeden 0.2 saniye önce (0.60 saniye sonra) başlasın
	task.delay(0.60, function()
		if shared.takeoffSound and shared.takeoffSound.IsPlaying then
			shared.takeoffSound:Play()
		end
	end)

	task.wait(0.80)

	-- Fly animasyonu başlat
	playAnimation("Fly", 1)

	-- BodyVelocity ve BodyGyro oluştur
	if not bodyVelocity then
		bodyVelocity = Instance.new("BodyVelocity")
		bodyVelocity.MaxForce = Vector3.new(1e6, 1e6, 1e6)
		bodyVelocity.Velocity = Vector3.zero
		bodyVelocity.Parent = rootPart
	end
	if not bodyGyro then
		bodyGyro = Instance.new("BodyGyro")
		bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
		bodyGyro.P, bodyGyro.D = 100000, 1000
		bodyGyro.Parent = rootPart
	end

	-- BodyGyro'yu anında yukarı yöne çevir
	bodyGyro.CFrame = CFrame.lookAt(rootPart.Position, rootPart.Position + Vector3.new(0, 1, 0))

	-- FOV 70 → 85 (0.25 saniye)
	local function tweenFOV(from, to, duration)
		local startFOV = from or camera.FieldOfView
		local targetFOV = to
		local startTime = tick()
		local con
		con = runService.RenderStepped:Connect(function()
			local elapsed = tick() - startTime
			local alpha = math.min(elapsed / duration, 1)
			local current = startFOV + (targetFOV - startFOV) * alpha
			camera.FieldOfView = current
			if alpha >= 1 then
				con:Disconnect()
			end
		end)
	end
	tweenFOV(70, 85, 0.25)

	-- 5 saniye boyunca kademeli olarak 0'dan 500'e çık
	local startTime = tick()
	local rampDuration = 5
	local startVel = 0
	local targetVel = 500
	local rampConnection
	rampConnection = runService.RenderStepped:Connect(function(dt)
		local elapsed = tick() - startTime
		local alpha = math.min(elapsed / rampDuration, 1)
		local smoothAlpha = alpha * alpha * (3 - 2 * alpha)
		local currentVel = startVel + (targetVel - startVel) * smoothAlpha
		bodyVelocity.Velocity = Vector3.new(0, currentVel, 0)
		if alpha >= 1 then
			rampConnection:Disconnect()
			bodyVelocity.Velocity = Vector3.new(0, targetVel, 0)
		end
	end)

	task.wait(rampDuration)

	-- FOV 85 → 70 (0.25 saniye)
	tweenFOV(85, 70, 0.25)

	-- Ses bitene kadar çalsın
	if shared.takeoffSound and shared.takeoffSound.IsPlaying then
		task.wait(shared.takeoffSound.TimeLength - shared.takeoffSound.TimePosition)
	end

	if shared.takeoffSound then
		shared.takeoffSound:Stop()
		shared.takeoffSound:Destroy()
		shared.takeoffSound = nil
	end

	-- BodyGyro'yu dümdüz öne hizala (dik duruş)
	local currentLook = rootPart.CFrame.LookVector
	local flatLook = Vector3.new(currentLook.X, 0, currentLook.Z)
	if flatLook.Magnitude > 0.001 then
		flatLook = flatLook.Unit
	else
		flatLook = Vector3.new(0, 0, -1)
	end
	bodyGyro.CFrame = CFrame.lookAt(rootPart.Position, rootPart.Position + flatLook, Vector3.new(0, 1, 0))

	shared.takeoffPlaying = false
	shared.flying = true
	updateCollision()
	bodyVelocity.Velocity = Vector3.zero

	-- Camera follow'u eski haline döndür
	shared.settings.cameraFollow = oldCameraFollow
	if oldCameraFollow then
		local look, up = camera.CFrame.LookVector, camera.CFrame.UpVector
		bodyGyro.CFrame = CFrame.lookAt(rootPart.Position, rootPart.Position + look, up)
	end
end

local function startFloating()
	if shared.floating then return end
	if not shared.tracks.FlyIdle[1] and reloadAnimationsCallback and character then
		reloadAnimationsCallback(character)
	end
	shared.floating = true
	updateCollision()
	bodyVelocity = Instance.new("BodyVelocity")
	bodyVelocity.MaxForce = Vector3.new(1e6, 1e6, 1e6)
	bodyVelocity.Velocity = Vector3.zero
	bodyVelocity.Parent = rootPart
	bodyGyro = Instance.new("BodyGyro")
	bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
	bodyGyro.P, bodyGyro.D = 100000, 1000
	bodyGyro.Parent = rootPart
	if shared.settings.cameraFollow then
		local look, up = camera.CFrame.LookVector, camera.CFrame.UpVector
		bodyGyro.CFrame = CFrame.lookAt(rootPart.Position, rootPart.Position + look, up)
	end
	playAnimation("FlyIdle", shared.currentIndices.FlyIdle)
end

local function stopFly(noCrossfade)
	if shared.flying then
		shared.flying = false
	end
	if shared.floating then
		shared.floating = false
	end
	if bodyVelocity then bodyVelocity:Destroy(); bodyVelocity = nil end
	if bodyGyro then bodyGyro:Destroy(); bodyGyro = nil end
	updateCollision()
	if shared.originalFOV then
		camera.FieldOfView = shared.originalFOV
		shared.originalFOV = nil
	end
	shared.targetIntensity, shared.targetZoom, shared.shakeTime = 0, 0, 0
	if noCrossfade then
		if shared.currentTrack then shared.currentTrack:Stop(0); shared.currentTrack = nil end
		shared.currentType = nil
	else
		stopCurrentTrack()
	end
	updateIdleState()

	if shared.takeoffSound then
		shared.takeoffSound:Stop()
		shared.takeoffSound:Destroy()
		shared.takeoffSound = nil
	end
end

local function performLanding()
	if shared.laserActive and shared.settings.laserFlingEnabled then
		return
	end
	if not shared.settings.landingEnabled or shared.landingCooldown or not humanoid then return end
	shared.landingShakeTime = 1
	if shared.flying then stopFly(true) end
	shared.landingCooldown = true
	local rootPos = rootPart.Position
	local currentYRotation = rootPart.Orientation.Y
	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.FilterDescendantsInstances = {character}
	local rayResult = workspace:Raycast(rootPos + Vector3.new(0, 5, 0), Vector3.new(0, -20, 0), rayParams)
	local newY
	if rayResult then
		local hipHeight = humanoid.HipHeight or 1
		local halfHeight = rootPart.Size.Y / 2
		newY = rayResult.Position.Y + hipHeight + halfHeight
	else
		newY = rootPos.Y
	end
	local landingCF = CFrame.new(rootPos.X, newY, rootPos.Z) * CFrame.Angles(0, math.rad(currentYRotation), 0)
	rootPart.CFrame = landingCF
	shared.landingPosition = landingCF
	spawnGroundBlocks(rootPart.Position)
	if animator then
		for _, trackList in pairs(shared.tracks) do
			for _, track in pairs(trackList) do
				if track and track.IsPlaying then track:Stop(0) end
			end
		end
	end
	shared.currentTrack = nil
	shared.currentType = nil
	shared.oldWalkSpeed = humanoid.WalkSpeed
	shared.oldJumpPower = humanoid.JumpPower
	shared.oldAutoRotate = humanoid.AutoRotate
	humanoid.WalkSpeed, humanoid.JumpPower, humanoid.AutoRotate = 0, 0, false
	local landingBodyVelocity = nil
	if rootPart then
		landingBodyVelocity = Instance.new("BodyVelocity")
		landingBodyVelocity.MaxForce = Vector3.new(9e6, 9e6, 9e6)
		landingBodyVelocity.Velocity = Vector3.new(0, 0, 0)
		landingBodyVelocity.Parent = rootPart
	end
	local landingTrack = nil
	if shared.tracks.Landing and shared.tracks.Landing[1] then
		landingTrack = shared.tracks.Landing[1]
		landingTrack:Play(0)
		landingTrack.Priority = Enum.AnimationPriority.Action4
		shared.currentTrack = landingTrack
		shared.currentType = "Landing"
	end
	if landingTrack then
		local finished = false
		local conn = landingTrack.Stopped:Connect(function() finished = true; conn:Disconnect() end)
		local timeout = tick() + 10
		while not finished and tick() < timeout do
			if rootPart then
				rootPart.AssemblyLinearVelocity = Vector3.zero
				rootPart.AssemblyAngularVelocity = Vector3.zero
			end
			task.wait()
		end
		if not finished then landingTrack:Stop(0) end
	end
	if landingBodyVelocity then landingBodyVelocity:Destroy() end
	if humanoid then
		humanoid.WalkSpeed = shared.oldWalkSpeed
		humanoid.JumpPower = shared.oldJumpPower
		humanoid.AutoRotate = shared.oldAutoRotate
	end
	if shared.currentTrack and shared.currentTrack == landingTrack then shared.currentTrack = nil end
	shared.currentType = nil
	shared.landingCooldown = false
	shared.landingPosition = nil
end

local function createLaserBeams(offset)
	local head = character and character:FindFirstChild("Head")
	if not head then return nil end
	local startAttachment = Instance.new("Attachment")
	startAttachment.Parent = head
	startAttachment.Position = Vector3.new(
		offset.X + shared.laserSettings.offsetX,
		offset.Y + shared.laserSettings.offsetY,
		offset.Z
	)
	local endPart = Instance.new("Part")
	endPart.Anchored = true
	endPart.CanCollide = false
	endPart.Transparency = 1
	endPart.Size = Vector3.new(1,1,1)
	endPart.Parent = workspace
	local endAttachment = Instance.new("Attachment")
	endAttachment.Parent = endPart

	local function newBeam(width, color, trans)
		local b = Instance.new("Beam")
		b.Attachment0 = startAttachment
		b.Attachment1 = endAttachment
		b.FaceCamera = true
		b.LightEmission = shared.laserSettings.brightness
		b.Width0 = width
		b.Width1 = width
		b.Color = ColorSequence.new(color)
		b.Transparency = NumberSequence.new(trans)
		b.Parent = head
		return b
	end

	local colors = getLaserColors()
	local outer = newBeam(0.7, colors.outer, 0.5)
	local middle = newBeam(0.35, colors.middle, 0.15)
	local coreWidth = 0.08 * shared.laserSettings.thickness
	local core = newBeam(coreWidth, colors.core, 0)
	return {
		endPart = endPart,
		startAttachment = startAttachment,
		endAttachment = endAttachment,
		outer = outer,
		middle = middle,
		core = core
	}
end

local function destroyLaserObjects()
	if laserLeftEnd then
		for _, obj in pairs(laserLeftEnd) do if obj and obj.Destroy then obj:Destroy() end end
		laserLeftEnd = nil
	end
	if laserRightEnd then
		for _, obj in pairs(laserRightEnd) do if obj and obj.Destroy then obj:Destroy() end end
		laserRightEnd = nil
	end
end

