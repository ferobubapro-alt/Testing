				-- Tek ses
				if selected.soundId then
					local sound = Instance.new("Sound")
					sound.SoundId = selected.soundId
					sound.Volume = 1
					sound.Parent = character and character:FindFirstChild("Head") or workspace
					sound:Play()
					sound.Ended:Connect(function() sound:Destroy() end)
				end
				-- Birden fazla ses (sırayla oynat, her ses bitince 1 saniye bekle)
				if selected.soundIds and #selected.soundIds > 0 then
					task.spawn(function()
						for idx, id in ipairs(selected.soundIds) do
							local sound = Instance.new("Sound")
							sound.SoundId = id
							sound.Volume = 1
							sound.Parent = character and character:FindFirstChild("Head") or workspace
							sound:Play()
							local finished = false
							local conn = sound.Ended:Connect(function()
								finished = true
								conn:Disconnect()
							end)
							while not finished do
								task.wait()
							end
							sound:Destroy()
							if idx < #selected.soundIds then
								task.wait(1)
							end
						end
					end)
				end
				menuFrame.Visible = false
				quoteMenuVisible = false
			end
		end)
	end

	return menuFrame
