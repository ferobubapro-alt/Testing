end

if (shared.flying or shared.floating) and rootPart and humanoid and not shared.isFlinging then
	if not shared.floating then
		shared.accelerateNormalSpeed(dt)
	end
	local moveDir = humanoid.MoveDirection
	if moveDir.Magnitude > 0.05 then
		if shared.flying and shared.currentType ~= "Fly" then
			shared.playAnimation("Fly", shared.currentIndices.Fly or 1)
		end
		local forward = camera.CFrame.LookVector
		local flatForward = Vector3.new(forward.X, 0, forward.Z)
		if flatForward.Magnitude > 0 then
			flatForward = flatForward.Unit
		end
		local right = Vector3.new(camera.CFrame.RightVector.X, 0, camera.CFrame.RightVector.Z)
		if right.Magnitude > 0 then
			right = right.Unit
		end
		local forwardAmount = moveDir:Dot(flatForward)
		local rightAmount = moveDir:Dot(right)
		local velocity = flatForward * (forwardAmount * shared.currentSpeed) +
			right * (rightAmount * shared.currentSpeed) +
			Vector3.new(0, forward.Y * forwardAmount * shared.currentSpeed, 0)
		bodyVelocity.Velocity = velocity
	else
		if shared.currentType ~= "FlyIdle" and shared.currentType ~= "LaserIdle" then
			shared.updateIdleState()
		end
		bodyVelocity.Velocity = Vector3.zero
	end
	shared.updateSmoothEffects(dt)
	shared.updateCamera(dt)
elseif shared.isFlinging and bodyVelocity then
	bodyVelocity.Velocity = Vector3.new(0,0,0)
else
	shared.updateCamera(dt)
end
