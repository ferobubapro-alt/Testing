local function updateLaser(dt)
	if not character or not character:FindFirstChild("Head") then destroyLaserObjects(); return end
	local head = character.Head
	if shared.laserActive then
		shared.laserCurrentDistance = math.min(shared.laserCurrentDistance + shared.laserExtendSpeed * dt, shared.laserMaxDistance)
		if not laserLeftEnd or not laserRightEnd then
			destroyLaserObjects()
			local sp = shared.laserSettings.spacing
			laserLeftEnd = createLaserBeams(Vector3.new(-sp, 0.05, -0.48))
			laserRightEnd = createLaserBeams(Vector3.new(sp, 0.05, -0.48))
		end
        local rayParams = RaycastParams.new()
        rayParams.FilterType = Enum.RaycastFilterType.Exclude
        rayParams.FilterDescendantsInstances = {character}
        local rayResult = workspace:Raycast(head.Position, head.CFrame.LookVector * shared.laserCurrentDistance, rayParams)
        if rayResult and rayResult.Instance then
            local hitModel = rayResult.Instance:FindFirstAncestorOfClass("Model")
            local hitPlayer = hitModel and Players:GetPlayerFromCharacter(hitModel)
            if hitPlayer and hitPlayer ~= player and not shared.isFlinging and shared.settings.laserFlingEnabled then
                task.spawn(function() shared.SkidFling(hitPlayer) end)
            end
        end
	else
		shared.laserCurrentDistance = math.max(shared.laserCurrentDistance - shared.laserRetractSpeed * dt, 0)
		if shared.laserCurrentDistance <= 0 then destroyLaserObjects() end
	end
	if laserLeftEnd and laserRightEnd then
		local look = head.CFrame.LookVector
		local forwardOffset = look * shared.laserCurrentDistance
		local leftPos = (head.Position + head.CFrame.RightVector * -shared.laserSettings.spacing + Vector3.new(0,0.05,0)) + forwardOffset
		local rightPos = (head.Position + head.CFrame.RightVector * shared.laserSettings.spacing + Vector3.new(0,0.05,0)) + forwardOffset
		laserLeftEnd.endPart.Position = leftPos
		laserRightEnd.endPart.Position = rightPos
	end
end

local function toggleLaser()
    if shared.laserActive then
        shared.laserActive = false
        stopLaserSound()
        HideGodBubble()
        StopLaserVignette()
        StopLaserShake()
        updateIdleState()
    else
        shared.laserActive = true
        shared.laserCurrentDistance = 0
        StartLaserVignette()
        StartLaserShake()
        startLaserSound()
        ShowGodBubble()
        updateIdleState()
    end
end

shared.updateLaserSettings = function(setting, value)
    if setting == "offsetX" then
        shared.laserSettings.offsetX = math.clamp(value, -1, 1)
    elseif setting == "offsetY" then
        shared.laserSettings.offsetY = math.clamp(value, -1, 1)
    elseif setting == "thickness" then
        shared.laserSettings.thickness = math.clamp(value, 0.1, 3)
    elseif setting == "brightness" then
        shared.laserSettings.brightness = math.clamp(value, 0.1, 3)
    elseif setting == "spacing" then
        shared.laserSettings.spacing = math.clamp(value, 0.05, 1.0)
    end
    if shared.laserActive then
        destroyLaserObjects()
        local sp = shared.laserSettings.spacing
        laserLeftEnd = createLaserBeams(Vector3.new(-sp, 0.05, -0.48))
        laserRightEnd = createLaserBeams(Vector3.new(sp, 0.05, -0.48))
    end
end

